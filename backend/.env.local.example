AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
ARO_RG=example-aro-rg
ARO_CLUSTER=example-aro-cluster
AOAI_RG=example-aoai-rg
AOAI_ACCOUNT=example-aoai-account
AOAI_DEPLOYMENT=gpt-5.2
AI_PROVIDER=azure-openai
AI_MOCK_MODE=false
AI_STRICT_STARTUP=true
AI_MODEL=gpt-5.2
AI_AZURE_OPENAI_ENDPOINT=https://example-openai-account.openai.azure.com
AI_AZURE_OPENAI_DEPLOYMENT=gpt-5.2
AI_AZURE_OPENAI_API_VERSION=2024-10-21
AI_AZURE_OPENAI_API_KEY=replace-with-local-secret
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret
AUTH_SESSION_SECRET=replace-with-long-random-session-secret
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret-key
ANTI_ABUSE_HMAC_SECRET=replace-with-long-random-anti-abuse-secret
# Optional per-route deployment overrides (fall back to AI_AZURE_OPENAI_DEPLOYMENT)
# AI_AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-5.2
# AI_AZURE_OPENAI_DEPLOYMENT_COMMAND=gpt-4o-mini
# AI_AZURE_OPENAI_DEPLOYMENT_SCENARIO=gpt-4o-mini
# Token budget and reasoning tuning
# AI_REASONING_EFFORT=medium
# AI_MAX_CHAT_TOKENS=16384
# AI_MAX_COMMAND_TOKENS=8192
# AI_COMMAND_TIMEOUT_MS=20000
# COMPACTION_TOKEN_BUDGET=12000
# COMPACTION_TAIL_MESSAGES=4
