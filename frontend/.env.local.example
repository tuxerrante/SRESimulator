BACKEND_INTERNAL_BASE_URL=http://127.0.0.1:8080
PUBLIC_APP_ORIGIN=http://localhost:3000
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret
AUTH_SESSION_SECRET=replace-with-long-random-session-secret
ANTI_ABUSE_HMAC_SECRET=replace-with-long-random-anti-abuse-secret
TRUST_PROXY_HEADERS=false
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key
# Google Cloud region where Claude is available on Vertex AI
# Common regions: us-east5, us-central1, europe-west1
CLOUD_ML_REGION=us-east5

# Your GCP project ID (not project number)
ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
